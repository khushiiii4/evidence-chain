# ── Blockchain ─────────────────────────────────────────────
# Local Hardhat node URL (default)
RPC_URL=http://127.0.0.1:8545

# Address printed after running: npm run deploy  (inside /blockchain)
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Private key of the first Hardhat test account (shown when you run `npx hardhat node`)
# ⚠️  Never use a real wallet private key with real funds here
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Pinata IPFS ────────────────────────────────────────────
# Get your JWT from https://app.pinata.cloud → API Keys → New Key
PINATA_JWT=your_pinata_jwt_token_here

# ── Server ─────────────────────────────────────────────────
PORT=5000
